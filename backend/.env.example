TICKETMASTER_API_KEY=your_key_here
DATABASE_URL=jdbc:sqlite:./eventdemand.db
PORT=8080
CACHE_TTL_HOURS=6

# SeatGeek Partner API — free self-serve client_id from platform.seatgeek.com
SEATGEEK_CLIENT_ID=your_client_id_here
# Secondary-market price cache TTL (prices are more volatile than event listings)
PRICE_CACHE_TTL_MINUTES=60

# StubHub and Vivid Seats require a partner/affiliate agreement — no self-serve API.
# Leave unset; these providers report "unavailable" gracefully until credentials exist.
#STUBHUB_API_KEY=
#VIVIDSEATS_API_KEY=

# Charles Proxy — uncomment to route HTTP client traffic through Charles
#CHARLES_PROXY_HOST=127.0.0.1
#CHARLES_PROXY_PORT=8888
